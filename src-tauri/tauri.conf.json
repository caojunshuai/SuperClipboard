{
  "$schema": "https://raw.githubusercontent.com/nicegui-org/tauri2-docs/refs/heads/master/tauri.conf.schema.json",
  "productName": "SuperClipboard",
  "version": "0.3.0",
  "identifier": "com.superclipboard.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "SuperClipboard",
        "width": 400,
        "height": 800,
        "resizable": true,
        "minWidth": 350,
        "minHeight": 380,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
